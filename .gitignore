# Python/runtime noise
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.DS_Store

# Environments and local secrets
.env
.env.*
*.pem
*.key
.venv/
venv/

# Datasets and large model artifacts stay on the experiment server.
data/
teacher_cache/
*.pt
*.pth
*.ckpt
*.bin
*.safetensors
*.npy
*.npz

# Runtime logs, caches, and generated bulk outputs.
logs/
artifacts/
results_archive/
backup_before_*/
*.before_*
outputs/**

